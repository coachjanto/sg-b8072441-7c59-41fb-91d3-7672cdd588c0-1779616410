  "ai_consultant": {
    "name": "Claudia Yang",
    "persona": "AI travel & content consultant for Djojo family Osaka trip",
    "language": "Bahasa Indonesia (natural, friendly tone)",
    "capabilities": [
      "Itinerary planning & route optimization",
      "Restaurant recommendations & budget meals",
      "Content strategy for Coach Janto's channel (Reels, posts)",
      "Transportation info (prices, schedules, routes)",
      "Attraction details (ticket prices, opening hours)",
      "Trip reminders & milestone alerts",
      "Spontaneous plan suggestions"
    ],
    "context_sources": [
      "Knowledge Base entries (text + uploaded files)",
      "Conversation history (last 5 messages)",
      "Current user name",
      "Trip dates (June 29 - July 13, 2026)"
    ],
    "api_configuration": {
      "providers": ["claude", "openai"],
      "default_provider": "claude",
      "claude_models": [
        "claude-3-5-sonnet-20240620 (Recommended)",
        "claude-3-haiku-20240307 (Fast & Affordable)",
        "claude-3-opus-20240229 (Most Capable)"
      ],
      "openai_models": [
        "gpt-4o (Recommended)",
        "gpt-4o-mini (Fast & Affordable)",
        "gpt-4-turbo",
        "gpt-3.5-turbo (Budget)"
      ],
      "validation": {
        "claude_key_format": "Must start with sk-ant-api",
        "openai_key_format": "Must start with sk-"
      }
    }
  },

  "core_features": {
    "chat_interface": {
      "description": "Real-time chat with Claudia Yang AI consultant",
      "implementation": [
        "Message history with sender name + timestamp",
        "User messages (right-aligned, primary bg)",
        "AI messages (left-aligned, glass card bg)",
        "Avatar display (Claudia photo for AI, user initial for members)",
        "Auto-scroll to latest message",
        "Enter to send, Shift+Enter for newline",
        "Loading state with animated dots",
        "Error handling with Indonesian error messages"
      ],
      "api_route": "/api/chat (POST)",
      "request_payload": {
        "message": "User input text",
        "provider": "claude | openai",
        "apiKey": "Trimmed API key",
        "model": "Model ID (cleaned from display text)",
        "currentUser": "Username",
        "knowledgeContext": "Concatenated knowledge base entries",
        "conversationHistory": "Last 5 messages array"
      }
    },

    "knowledge_base": {
      "description": "Admin-managed context repository for Claudia Yang",
      "entry_types": [
        {
          "type": "text",
          "fields": ["title", "content", "category"],
          "use_case": "Trip info, itinerary details, restaurant lists, tips"
        },
        {
          "type": "file",
          "supported_formats": [".pdf", ".doc", ".docx", ".txt", ".md", ".jpg", ".png"],
          "fields": ["title", "fileName", "fileUrl", "category"],
          "use_case": "Flight tickets, booking confirmations, maps, menus"
        }
      ],
      "categories": [
        "Trip Info",
        "Itinerary",
        "Budget & Finance",
        "Content Strategy",
        "Travel Tips",
        "Restaurant List",
        "Transportation",
        "Accommodation",
        "Emergency Info",
        "Other"
      ],
      "storage": "localStorage (key: knowledge_base)",
      "format": "JSON array with id, title, content, category, type, createdAt"
    },

    "expense_tracker": {
      "status": "Placeholder (to be implemented)",
      "planned_features": [
        "Multi-currency logging (JPY ↔ IDR conversion)",
        "Receipt photo upload",
        "GPS location tagging",
        "Category breakdown (Food, Transport, Shopping, etc.)",
        "Shared expense splitting",
        "Budget vs actual comparison",
        "Per-member spending analysis",
        "PDF/Excel export"
      ]
    },

    "document_vault": {
      "status": "Placeholder (to be implemented)",
      "planned_features": [
        "Centralized storage for passports, flights, bookings",
        "PIN-protected sensitive data",
        "Quick access with search/filter",
        "PDF viewer integration",
        "Share selected docs with guest users"
      ]
    },

    "souvenir_wishlist": {
      "status": "Placeholder (to be implemented)",
      "planned_features": [
        "Request tracking with status (pending/bought/delivered)",
        "Price comparison across stores",
        "Proof photos when purchased",
        "Member-specific wishlists",
        "Budget allocation per item"
      ]
    },

    "media_gallery": {
      "status": "Placeholder (to be implemented)",
      "planned_features": [
        "Google Drive integration",
        "GPS metadata for photos",
        "Auto-organize by date/location",
        "Album creation",
        "Share to social media",
        "Download all as ZIP"
      ]
    }
  },

  "admin_dashboard": {
    "access": "Super Admin only",
    "tabs": [
      {
        "id": "api-keys",
        "title": "API Configuration",
        "features": [
          "AI Provider selection (Claude / OpenAI)",
          "Model dropdown (filtered by provider)",
          "API key input with show/hide toggle",
          "Google Drive API key (optional)",
          "Format validation before save",
          "Test Connection button with detailed results",
          "Save to localStorage (admin_settings)"
        ]
      },
      {
        "id": "knowledge",
        "title": "AI Knowledge Base",
        "features": [
          "Add text entry dialog (title, category, content)",
          "Upload file dialog (title, category, file picker)",
          "Entry list with category badges",
          "Edit text entries",
          "Delete entries with confirmation",
          "Search/filter by category (future)",
          "Save to localStorage (knowledge_base)"
        ]
      },
      {
        "id": "security",
        "title": "Security Settings",
        "features": [
          "6-digit PIN input",
          "Confirm PIN validation",
          "Save to localStorage (security_pin)",
          "Use PIN for document vault access"
        ]
      },
      {
        "id": "budget",
        "title": "Budget Configuration",
        "features": [
          "Total trip budget input (JPY)",
          "Per-pax billing toggle",
          "Save to localStorage (budget_settings)"
        ]
      },
      {
        "id": "members",
        "title": "Member Management",
        "features": [
          "Member list with role badges",
          "Add member dialog (name, email, password, role)",
          "Edit member dialog (update profile + password)",
          "Delete member with confirmation",
          "Toggle active/inactive status",
          "Super Admin cannot be deleted or deactivated",
          "Save to localStorage (members)"
        ]
      },
      {
        "id": "appearance",
        "title": "Style Settings",
        "features": [
          "Upload custom background image",
          "Auto-compress to 1280x720 max, JPEG 60% quality",
          "Preview before save",
          "Save to localStorage (app_background) as base64",
          "Apply as overlay in Layout.tsx (opacity 30%)"
        ]
      },
      {
        "id": "notifications",
        "title": "Notification Preferences",
        "status": "Coming soon placeholder"
      }
    ]
  },

  "navigation": {
    "bottom_nav": {
      "position": "Sticky bottom, full width",
      "style": "Glass effect with backdrop-blur-xl",
      "items": [
        {
          "id": "chat",
