        },
        {
          "id": "gallery",
          "icon": "Image",
          "label": "Gallery",
          "status": "Placeholder"
        },
        {
          "id": "admin",
          "icon": "Settings",
          "label": "Admin",
          "route": "/admin"
        }
      ],
      "responsive": {
        "mobile": "Vertical layout, larger icons, smaller text",
        "tablet_plus": "Horizontal layout, normal size"
      }
    },
    "theme_toggle": {
      "position": "Fixed top-right",
      "component": "ThemeSwitch with sun/moon icons"
    }
  },

  "authentication": {
    "type": "Simple localStorage-based (no Supabase Auth yet)",
    "flow": [
      "1. User enters username on LoginScreen",
      "2. Match against predefined members array",
      "3. Save session to localStorage (user_session)",
      "4. Show personalized welcome from Claudia Yang",
      "5. First login gets extended intro, subsequent logins get short greeting"
    ],
    "stored_data": {
      "user_session": "{ username: string }",
      "members": "Array of { id, name, email, role, isActive, password }",
      "[username]_has_logged_before": "boolean flag"
    },
    "logout": "Clear user_session from localStorage, redirect to LoginScreen"
  },

  "api_routes": {
    "/api/chat": {
      "method": "POST",
      "description": "Proxy for Claude/OpenAI API calls",
      "request_body": {
        "message": "string",
        "provider": "claude | openai",
        "apiKey": "string (trimmed)",
        "model": "string (model ID)",
        "currentUser": "string",
        "knowledgeContext": "string (formatted knowledge entries)",
        "conversationHistory": "array of { role, content }"
      },
      "response": {
        "success": "{ response: string }",
        "error": "{ error: string } with Indonesian error messages"
      },
      "error_handling": {
        "401": "API key tidak valid atau expired",
        "429": "Rate limit terlampaui atau quota habis",
        "400": "Format request tidak valid"
      }
    },
    "/api/hello": {
      "method": "GET",
      "description": "Health check endpoint",
      "response": "{ name: 'John Doe' }"
    }
  },

  "data_persistence": {
    "storage_method": "localStorage (client-side only)",
    "keys": {
      "user_session": "Current logged-in user",
      "admin_settings": "AI provider, API keys, model selection",
      "knowledge_base": "Array of knowledge entries",
      "budget_settings": "Total budget, per-pax billing flag",
      "security_pin": "6-digit PIN for sensitive data",
      "members": "Array of member profiles with passwords",
      "app_background": "Base64-encoded custom background image",
      "[username]_has_logged_before": "First login tracker"
    },
    "future_migration": "Migrate to Supabase for persistence, auth, realtime, and multi-device sync"
  },

  "responsive_design": {
    "breakpoints": {
      "sm": "640px (tablet)",
      "md": "768px (tablet landscape)",
      "lg": "1024px (desktop)"
    },
