{
  "project_name": "Japan2026 - Osaka Trip Companion",
  "description": "Mobile-first AI travel companion app for Djojo family Osaka trip (June 29 - July 13, 2026). Features Claudia Yang AI consultant powered by Claude/OpenAI, glassmorphism design with Japanese aesthetic, expense tracking, document vault, souvenir wishlist, and media gallery.",
  
  "tech_stack": {
    "framework": "Next.js 15 (Page Router)",
    "language": "TypeScript",
    "styling": "Tailwind CSS 3.4 + shadcn/ui components",
    "database": "Supabase (PostgreSQL + RLS)",
    "ai": "Claude API / OpenAI API (configurable)",
    "storage": "Supabase Storage + Google Drive API integration",
    "icons": "Lucide React",
    "fonts": {
      "display": "Noto Serif JP (Japanese headers)",
      "body": "DM Sans (readable body text)",
      "data": "JetBrains Mono (tabular numbers)"
    }
  },

  "design_system": {
    "style_direction": "Glassmorphism Modern Japanese",
    "color_palette": {
      "background_dark": "225 50% 8% (Deep navy #0a0f1e)",
      "background_light": "210 40% 98%",
      "foreground_dark": "224 100% 97% (Off-white #f0f4ff)",
      "foreground_light": "225 50% 12%",
      "primary": "47 78% 59% (Gold #e8c547)",
      "secondary": "199 91% 64% (Ice blue #4fc3f7)",
      "accent": "340 100% 71% (Sakura pink #ff6b9d)",
      "muted_dark": "225 30% 20% (Dark glass panels)",
      "muted_light": "210 30% 96%"
    },
    "visual_elements": [
      "Animated gradient mesh background (can be replaced with custom upload)",
      "Torii gate silhouette (3% opacity, SVG)",
      "Sakura petal floating particles (CSS animation)",
      "Glass effect cards (backdrop-blur-md, semi-transparent backgrounds)",
      "Light/dark theme toggle (top-right)"
    ],
    "layout": {
      "format": "Mobile-first 9:16 adaptive layout",
      "container": "Full-width with max-w-4xl centered content",
      "spacing_scale": "4px base (gap-1 to gap-8)",
      "border_radius": "rounded-xl (12px) for cards, rounded-2xl (16px) for containers"
    }
  },

  "user_roles": {
    "super_admin": {
      "name": "Janto Djojo",
      "email": "coach.janto@gmail.com",
      "password": "1100110011",
      "permissions": [
        "Full access to Admin Dashboard",
